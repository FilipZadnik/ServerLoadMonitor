<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:endColor="@color/auth_background_end"
                android:startColor="@color/auth_background_start" />
        </shape>
    </item>

    <item
        android:bottom="380dp"
        android:left="-120dp"
        android:right="-120dp"
        android:top="-240dp">
        <shape android:shape="rectangle">
            <gradient
                android:centerX="0.5"
                android:centerY="0.0"
                android:endColor="@android:color/transparent"
                android:gradientRadius="420dp"
                android:startColor="@color/auth_glow"
                android:type="radial" />
        </shape>
    </item>
</layer-list>
