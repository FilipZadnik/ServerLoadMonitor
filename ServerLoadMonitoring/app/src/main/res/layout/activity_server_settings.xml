<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_auth_screen">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingTop="10dp"
        android:paddingEnd="14dp"
        android:paddingBottom="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/buttonBackServerSettings"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/detail_back"
                android:padding="8dp"
                android:src="@drawable/ic_arrow_back_24"
                app:tint="@color/auth_text_primary" />

            <TextView
                android:id="@+id/textServerSettingsTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/server_settings_title_default"
                android:textColor="@color/auth_text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="10dp"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="@color/server_card_bg"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/server_card_stroke"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/server_settings_identity_title"
                                android:textColor="@color/auth_text_primary"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:hint="@string/add_server_name_label"
                                app:boxBackgroundColor="@color/auth_input_bg"
                                app:boxStrokeColor="@color/server_card_stroke">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/inputServerSettingsName"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="textPersonName"
                                    android:textColor="@color/auth_text_primary" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="14dp"
                                android:text="@string/server_settings_intervals_title"
                                android:textColor="@color/auth_text_primary"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:hint="@string/add_server_interval_label"
                                app:boxBackgroundColor="@color/auth_input_bg"
                                app:boxStrokeColor="@color/server_card_stroke">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/inputServerSettingsMetricInterval"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="number"
                                    android:textColor="@color/auth_text_primary" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:hint="@string/add_server_process_interval_label"
                                app:boxBackgroundColor="@color/auth_input_bg"
                                app:boxStrokeColor="@color/server_card_stroke">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/inputServerSettingsProcessInterval"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="number"
                                    android:textColor="@color/auth_text_primary" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:hint="@string/add_server_service_interval_label"
                                app:boxBackgroundColor="@color/auth_input_bg"
                                app:boxStrokeColor="@color/server_card_stroke">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/inputServerSettingsServiceInterval"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="number"
                                    android:textColor="@color/auth_text_primary" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="14dp"
                                android:text="@string/server_settings_data_retention_days"
                                android:textColor="@color/auth_text_primary"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:hint="@string/server_settings_data_retention_days_hint"
                                app:boxBackgroundColor="@color/auth_input_bg"
                                app:boxStrokeColor="@color/server_card_stroke">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/inputServerSettingsRetentionDays"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="number"
                                    android:textColor="@color/auth_text_primary" />
                            </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="@color/server_card_bg"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/server_card_stroke"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/server_settings_notifications"
                            android:textColor="@color/auth_text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/server_settings_notification_offline"
                                android:textColor="@color/auth_text_primary"
                                android:textSize="13sp" />

                            <com.google.android.material.switchmaterial.SwitchMaterial
                                android:id="@+id/switchServerSettingsNotifyOffline"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:checked="true" />
                        </LinearLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:hint="@string/server_settings_notification_cpu_threshold"
                            app:boxBackgroundColor="@color/auth_input_bg"
                            app:boxStrokeColor="@color/server_card_stroke">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/inputServerSettingsCpuThreshold"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="number"
                                android:textColor="@color/auth_text_primary" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:hint="@string/server_settings_notification_ram_threshold"
                            app:boxBackgroundColor="@color/auth_input_bg"
                            app:boxStrokeColor="@color/server_card_stroke">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/inputServerSettingsRamThreshold"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="number"
                                android:textColor="@color/auth_text_primary" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonSaveServerSettings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="@string/server_settings_save"
                    android:textAllCaps="false"
                    app:backgroundTint="@color/auth_accent"
                    app:strokeColor="@color/server_card_stroke"
                    app:strokeWidth="1dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonDeleteServer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/server_settings_delete_server"
                    android:textAllCaps="false"
                    android:textColor="@color/server_status_offline_text"
                    app:backgroundTint="@color/auth_input_bg"
                    app:strokeColor="@color/server_status_offline_text"
                    app:strokeWidth="1dp" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
