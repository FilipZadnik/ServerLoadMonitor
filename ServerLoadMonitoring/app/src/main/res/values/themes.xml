<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.ServerLoadMonitoring" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:forceDarkAllowed">false</item>
    </style>

    <style name="Theme.ServerLoadMonitoring" parent="Base.Theme.ServerLoadMonitoring" />

    <style name="Theme.ServerLoadMonitoring.GlobalOverlay" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowAnimationStyle">@style/GlobalOverlayNoAnimation</item>
    </style>

    <style name="GlobalOverlayNoAnimation">
        <item name="android:activityOpenEnterAnimation">@anim/none</item>
        <item name="android:activityOpenExitAnimation">@anim/none</item>
        <item name="android:activityCloseEnterAnimation">@anim/none</item>
        <item name="android:activityCloseExitAnimation">@anim/none</item>
    </style>
</resources>
